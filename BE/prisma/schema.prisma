generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum OAuthProvider {
  KAKAO
  GOOGLE
  APPLE
}

enum AuthSessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AuthDeviceStatus {
  ACTIVE
  REPLACED
  REVOKED
}

enum AuthDeviceSlot {
  MOBILE
  PERSONAL_LAPTOP
  WORK_LAPTOP
}

enum MeetingNoteSourceType {
  MANUAL
  TEXT_AI
  STT_AI
}

enum BusinessCardScanStatus {
  OCR_SUCCESS
  OCR_FAILED
  CONFIRMED
}

enum BusinessCardResolution {
  EXISTING
  CREATED
}

enum ImportTemplateType {
  COMPANY
  CONTACT
  PRODUCT
  DEAL
}

enum ImportJobStatus {
  UPLOADED
  MAPPED
  NEEDS_REVIEW
  READY_TO_CONFIRM
  CONFIRMING
  CONFIRMED
  FAILED
  CANCELED
  EXPIRED
}

enum ImportJobRowStatus {
  PENDING
  VALID
  INVALID
  EXCLUDED
  IMPORTED
  FAILED
}

enum ImportJobMappingSource {
  NONE
  AI
  RULE_BASED
  USER
}

enum ImportUploadedFileStatus {
  STORED
  PARSED
  DELETED
  EXPIRED
}

enum ImportJobErrorType {
  PARSE
  AI_MAPPING
  VALIDATION
  CONFIRM
  STORAGE
  SYSTEM
}

enum ImportJobErrorSeverity {
  INFO
  WARNING
  ERROR
}

enum NotificationType {
  SCHEDULE_START_REMINDER
  DEAL_DUE_REMINDER
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

enum NotificationSourceType {
  SCHEDULE
  DEAL
}

enum NotificationDeliveryChannel {
  EMAIL
  BROWSER_PUSH
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

enum BrowserPushSubscriptionStatus {
  ACTIVE
  REVOKED
}

enum ExternalCalendarProvider {
  GOOGLE
}

enum ExternalCalendarConnectionStatus {
  CONNECTED
  RECONNECT_REQUIRED
  DISCONNECTED
}

enum ExternalCalendarSourceStatus {
  SELECTED
  UNSELECTED
}

enum ScheduleSourceType {
  INTERNAL
  GOOGLE
}

enum ScheduleExternalSyncStatus {
  SYNCED
  LOCAL_MODIFIED
  GOOGLE_DELETED
  LOCAL_DELETED
}

enum AiWeeklySalesReportStatus {
  GENERATING
  READY
  FAILED
}

enum AiWeeklySalesReportSuggestionType {
  RISK
  NEXT_ACTION
  FOLLOW_UP
  DATA_CLEANUP
}

enum AiSuggestionPriority {
  LOW
  MEDIUM
  HIGH
}

enum AiJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum AiProviderOperation {
  WEEKLY_SALES_REPORT
  FOLLOW_UP_EMAIL_DRAFT
  FOLLOW_UP_SMS_DRAFT
}

enum AiProviderCallStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
}

enum ExternalEmailProvider {
  GOOGLE
  MICROSOFT
}

enum ExternalEmailConnectionStatus {
  CONNECTED
  RECONNECT_REQUIRED
  DISCONNECTED
}

enum SmsSenderNumberStatus {
  PENDING_VERIFICATION
  VERIFIED
  REVOKED
}

enum FollowUpDeliveryChannel {
  EMAIL
  SMS
}

enum FollowUpMessageStatus {
  DRAFT
  SENDING
  SENT
  FAILED
}

enum FollowUpTargetType {
  AI_WEEKLY_REPORT
  DEAL
  CONTACT
  MEETING_NOTE
  SCHEDULE
}

enum FollowUpDeliveryAttemptStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

model User {
  id                   String     @id @default(uuid()) @db.Uuid
  email                String?
  displayName          String?
  role                 UserRole   @default(USER)
  status               UserStatus @default(ACTIVE)
  timeZone             String     @default("Asia/Seoul")
  preferredLocale      String     @default("ko-KR")
  signupLocale         String?
  signupCountryCode    String?
  signupTimeZone       String?
  lastLoginLocale      String?
  lastLoginCountryCode String?
  lastLoginTimeZone    String?
  lastLoginAt          DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  deletedAt            DateTime?

  oauthAccounts               UserOAuthAccount[]
  authDevices                 AuthDevice[]
  authSessions                AuthSession[]
  /// 기능 : 사용자가 등록한 회사 목록이다.
  companies                   Company[]
  /// 기능 : 사용자가 만든 회사 분야 옵션 목록이다.
  companyFields               CompanyField[]
  /// 기능 : 사용자가 만든 회사 지역 옵션 목록이다.
  companyRegions              CompanyRegion[]
  /// 기능 : 사용자가 작성한 회사 일반 메모 로그 목록이다.
  companyMemoLogs             CompanyMemoLog[]
  /// 기능 : 사용자가 작성한 회사 개인 비밀 메모 로그 목록이다.
  companyPrivateMemoLogs      CompanyUserPrivateMemoLog[]
  /// 기능 : 사용자가 등록한 담당자 목록이다.
  contacts                    Contact[]
  /// 기능 : 사용자가 만든 담당자 직급 옵션 목록이다.
  contactJobGrades            ContactJobGrade[]
  /// 기능 : 사용자가 만든 담당자 부서 옵션 목록이다.
  contactDepartments          ContactDepartment[]
  /// 기능 : 사용자가 작성한 담당자 일반 메모 로그 목록이다.
  contactMemoLogs             ContactMemoLog[]
  /// 기능 : 사용자가 작성한 담당자 개인 비밀 메모 로그 목록이다.
  contactPrivateMemoLogs      ContactUserPrivateMemoLog[]
  /// 기능 : 사용자가 등록한 제품 목록이다.
  products                    Product[]
  /// 기능 : 사용자가 만든 제품 카테고리 옵션 목록이다.
  productCategories           ProductCategory[]
  /// 기능 : 사용자가 만든 제품 상태 옵션 목록이다.
  productStatuses             ProductStatus[]
  /// 기능 : 사용자가 작성한 제품 일반 메모 로그 목록이다.
  productMemoLogs             ProductMemoLog[]
  /// 기능 : 사용자가 작성한 제품 개인 비밀 메모 로그 목록이다.
  productPrivateMemoLogs      ProductUserPrivateMemoLog[]
  /// 기능 : 사용자가 등록한 딜 목록이다.
  deals                       Deal[]
  /// 기능 : 사용자가 딜에 연결한 회사 매핑 목록이다.
  dealCompanies               DealCompany[]
  /// 기능 : 사용자가 딜에 연결한 담당자 매핑 목록이다.
  dealContacts                DealContact[]
  /// 기능 : 사용자가 작성한 딜 다음 행동 로그 목록이다.
  dealFollowingActionLogs     DealFollowingActionLog[]
  /// 기능 : 사용자가 작성한 딜 메모 로그 목록이다.
  dealMemoLogs                DealMemoLog[]
  /// 기능 : 사용자가 딜에 연결한 제품 매핑 목록이다.
  dealProducts                DealProduct[]
  /// 기능 : 사용자가 등록한 일정 목록이다.
  schedules                   Schedule[]
  externalCalendarConnections ExternalCalendarConnection[]
  externalCalendarSources     ExternalCalendarSource[]
  /// 기능 : 사용자가 일정에 연결한 딜 매핑 목록이다.
  scheduleDeals               ScheduleDeal[]
  meetingNotes                MeetingNote[]
  meetingNoteCompanies        MeetingNoteCompany[]
  meetingNoteContacts         MeetingNoteContact[]
  meetingNoteProducts         MeetingNoteProduct[]
  meetingNoteDeals            MeetingNoteDeal[]
  businessCardScanLogs        BusinessCardScanLog[]
  importUserLogs              ImportUserLog[]
  importJobs                  ImportJob[]
  importJobRows               ImportJobRow[]
  importJobErrors             ImportJobError[]
  importUploadedFiles         ImportUploadedFile[]
  /// 기능 : 사용자의 알림 수신 설정 row입니다. 사용자당 하나만 허용합니다.
  notificationSetting         UserNotificationSetting?
  /// 기능 : 사용자에게 예약되거나 발송된 앱 안 알림 목록입니다.
  notifications               Notification[]
  /// 기능 : 사용자에게 시도된 email/browser push 발송 이력 목록입니다.
  notificationDeliveries      NotificationDeliveryAttempt[]
  /// 기능 : 사용자의 browser push 구독 정보를 암호화해 저장한 목록입니다.
  browserPushSubscriptions    BrowserPushSubscription[]
  /// 기능 : 사용자의 주간 AI 영업 리포트 version 목록입니다.
  aiWeeklySalesReports        AiWeeklySalesReport[]
  /// 기능 : 사용자의 주간 AI 리포트 제안 목록입니다.
  aiWeeklyReportSuggestions   AiWeeklySalesReportSuggestion[]
  /// 기능 : 사용자의 AI 비동기 작업 목록입니다.
  aiJobs                      AiJob[]
  /// 기능 : 사용자의 AI provider 호출 이력 목록입니다.
  aiProviderCallLogs          AiProviderCallLog[]
  /// Feature: external email account connections used for follow-up delivery.
  externalEmailConnections    ExternalEmailConnection[]
  /// Feature: short-lived OAuth state rows for follow-up email connections.
  externalEmailOAuthStates    ExternalEmailOAuthState[]
  /// Feature: verified sender phone numbers used for follow-up SMS delivery.
  smsSenderNumbers            SmsSenderNumber[]
  /// Feature: channel consent acknowledgements for user-initiated follow-up delivery.
  followUpConsentNotices      FollowUpConsentNotice[]
  /// Feature: AI/user follow-up draft and delivery history.
  followUpMessages            FollowUpMessage[]
  /// Feature: follow-up message target links for timeline/history.
  followUpMessageTargets      FollowUpMessageTarget[]
  /// Feature: provider send attempt logs for follow-up messages.
  followUpDeliveryAttempts    FollowUpDeliveryAttempt[]

  @@index([role])
  @@index([status])
  @@index([createdAt])
}

model UserOAuthAccount {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String        @db.Uuid
  provider         OAuthProvider
  providerUserId   String
  providerEmail    String?
  accessTokenHash  String?
  refreshTokenHash String?
  tokenExpiresAt   DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId])
  @@index([userId])
}

model AuthDevice {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @db.Uuid
  deviceSlot   AuthDeviceSlot
  deviceIdHash String
  label        String?
  status       AuthDeviceStatus @default(ACTIVE)
  lastSeenAt   DateTime?
  replacedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user     User          @relation(fields: [userId], references: [id])
  sessions AuthSession[]

  @@index([userId])
  @@index([userId, deviceSlot, status])
  @@index([userId, deviceIdHash])
}

model AuthSession {
  id               String            @id @default(uuid()) @db.Uuid
  userId           String            @db.Uuid
  authDeviceId     String            @db.Uuid
  status           AuthSessionStatus @default(ACTIVE)
  refreshTokenHash String?
  userAgent        String?
  ipAddressHash    String?
  lastUsedAt       DateTime?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user       User       @relation(fields: [userId], references: [id])
  authDevice AuthDevice @relation(fields: [authDeviceId], references: [id])

  @@index([userId])
  @@index([authDeviceId])
  @@index([status])
  @@index([expiresAt])
}

model Company {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  companyName     String
  companyFieldId  String    @db.Uuid
  companyRegionId String    @db.Uuid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime? @db.Timestamptz(3)
  deletedByUserId String?   @db.Uuid
  trashExpiresAt  DateTime? @db.Timestamptz(3)

  /// 기능 : 회사를 생성한 사용자다. 모든 회사 API는 이 userId로 소유권을 검증한다.
  user                 User                        @relation(fields: [userId], references: [id])
  /// 기능 : 회사 목록 필터에 사용되는 회사 분야다.
  companyField         CompanyField                @relation(fields: [companyFieldId], references: [id])
  /// 기능 : 회사 목록 필터에 사용되는 회사 지역이다.
  companyRegion        CompanyRegion               @relation(fields: [companyRegionId], references: [id])
  /// 기능 : 회사 특징에 대한 일반 메모 로그 목록이다.
  memoLogs             CompanyMemoLog[]
  /// 기능 : 작성자 본인만 복호화해 볼 수 있는 회사 개인 비밀 메모 로그 목록이다.
  privateMemoLogs      CompanyUserPrivateMemoLog[]
  /// 기능 : 회사에 소속된 담당자 목록이다.
  contacts             Contact[]
  /// 기능 : 회사가 연결된 딜 매핑 목록이다.
  dealCompanies        DealCompany[]
  meetingNoteCompanies MeetingNoteCompany[]
  meetingNoteContacts  MeetingNoteContact[]
  businessCardScanLogs BusinessCardScanLog[]

  @@index([userId, createdAt])
  @@index([userId, companyName])
  @@index([userId, companyFieldId])
  @@index([userId, companyRegionId])
  @@index([userId, deletedAt])
  @@index([userId, trashExpiresAt])
}

model Contact {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @db.Uuid
  companyId           String    @db.Uuid
  username            String
  mobile              String
  email               String
  contactJobGradeId   String    @db.Uuid
  contactDepartmentId String    @db.Uuid
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime? @db.Timestamptz(3)
  deletedByUserId     String?   @db.Uuid
  trashExpiresAt      DateTime? @db.Timestamptz(3)

  /// 기능 : 담당자를 등록한 사용자다. 모든 담당자 API는 이 userId로 소유권을 검증한다.
  user                 User                        @relation(fields: [userId], references: [id])
  /// 기능 : 담당자가 소속된 회사다. 담당자는 회사 없이 저장되지 않는다.
  company              Company                     @relation(fields: [companyId], references: [id])
  /// 기능 : 담당자 목록 필터와 상세에 사용되는 담당자 직급이다.
  contactJobGrade      ContactJobGrade             @relation(fields: [contactJobGradeId], references: [id])
  /// 기능 : 담당자 목록 필터와 상세에 사용되는 담당자 부서다.
  contactDepartment    ContactDepartment           @relation(fields: [contactDepartmentId], references: [id])
  /// 기능 : 담당자 일반 메모 로그 목록이다.
  memoLogs             ContactMemoLog[]
  /// 기능 : 작성자 본인만 복호화해 볼 수 있는 담당자 개인 비밀 메모 로그 목록이다.
  privateMemoLogs      ContactUserPrivateMemoLog[]
  /// 기능 : 담당자가 연결된 딜 매핑 목록이다.
  dealContacts         DealContact[]
  meetingNoteContacts  MeetingNoteContact[]
  businessCardScanLogs BusinessCardScanLog[]
  followUpMessages     FollowUpMessage[]

  @@index([userId, createdAt])
  @@index([userId, username])
  @@index([userId, companyId])
  @@index([userId, contactDepartmentId])
  @@index([userId, contactJobGradeId])
  @@index([userId, deletedAt])
  @@index([userId, trashExpiresAt])
}

model ContactJobGrade {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  jobGradeName String
  createdAt    DateTime @default(now())

  /// 기능 : 담당자 직급을 생성한 사용자다.
  user     User      @relation(fields: [userId], references: [id])
  /// 기능 : 이 직급을 사용하는 담당자 목록이다. 하나라도 있으면 직급 삭제를 막는다.
  contacts Contact[]

  @@unique([userId, jobGradeName])
  @@index([userId])
}

model ContactDepartment {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  departmentName String
  createdAt      DateTime @default(now())

  /// 기능 : 담당자 부서를 생성한 사용자다.
  user     User      @relation(fields: [userId], references: [id])
  /// 기능 : 이 부서를 사용하는 담당자 목록이다. 하나라도 있으면 부서 삭제를 막는다.
  contacts Contact[]

  @@unique([userId, departmentName])
  @@index([userId])
}

model ContactMemoLog {
  id              String    @id @default(uuid()) @db.Uuid
  contactId       String    @db.Uuid
  userId          String    @db.Uuid
  memoType        String
  memo            String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime? @db.Timestamptz(3)
  deletedByUserId String?   @db.Uuid
  trashExpiresAt  DateTime? @db.Timestamptz(3)

  /// 기능 : 메모가 속한 담당자다.
  contact Contact @relation(fields: [contactId], references: [id])
  /// 기능 : 메모를 작성한 사용자다.
  user    User    @relation(fields: [userId], references: [id])

  @@index([contactId, createdAt])
  @@index([userId, contactId])
  @@index([userId, deletedAt])
  @@index([userId, trashExpiresAt])
}

model ContactUserPrivateMemoLog {
  id              String    @id @default(uuid()) @db.Uuid
  contactId       String    @db.Uuid
  userId          String    @db.Uuid
  memoCiphertext  String
  memoKeyVersion  String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime? @db.Timestamptz(3)
  deletedByUserId String?   @db.Uuid
  trashExpiresAt  DateTime? @db.Timestamptz(3)

  /// 기능 : 비밀 메모가 속한 담당자다.
  contact Contact @relation(fields: [contactId], references: [id])
  /// 기능 : 비밀 메모를 작성한 사용자다. 이 사용자만 복호화된 memo를 볼 수 있다.
  user    User    @relation(fields: [userId], references: [id])

  @@index([contactId, createdAt])
  @@index([userId, contactId])
  @@index([userId, deletedAt])
  @@index([userId, trashExpiresAt])
}

model Product {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  productName       String
  productPrice      Int
  productCategoryId String    @db.Uuid
  productStatusId   String    @db.Uuid
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime? @db.Timestamptz(3)
  deletedByUserId   String?   @db.Uuid
  trashExpiresAt    DateTime? @db.Timestamptz(3)

  /// 기능 : 제품을 등록한 사용자다. 모든 제품 API는 이 userId로 소유권을 검증한다.
  user                User                        @relation(fields: [userId], references: [id])
  /// 기능 : 제품 목록 필터와 상세에 사용되는 제품 카테고리다.
  productCategory     ProductCategory             @relation(fields: [productCategoryId], references: [id])
  /// 기능 : 제품 목록 필터와 상세에 사용되는 제품 상태다.
  productStatus       ProductStatus               @relation(fields: [productStatusId], references: [id])
  /// 기능 : 제품 일반 메모 로그 목록이다.
  memoLogs            ProductMemoLog[]
  /// 기능 : 작성자 본인만 복호화해 볼 수 있는 제품 개인 비밀 메모 로그 목록이다.
  privateMemoLogs     ProductUserPrivateMemoLog[]
  /// 기능 : 제품이 연결된 딜 매핑 목록이다.
  dealProducts        DealProduct[]
  meetingNoteProducts MeetingNoteProduct[]

  @@index([userId, createdAt])
  @@index([userId, productName])
  @@index([userId, productCategoryId])
  @@index([userId, productStatusId])
  @@index([userId, deletedAt])
  @@index([userId, trashExpiresAt])
}

model ProductCategory {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  categoryName String
  createdAt    DateTime @default(now())

  /// 기능 : 제품 카테고리를 생성한 사용자다.
  user     User      @relation(fields: [userId], references: [id])
  /// 기능 : 이 카테고리를 사용하는 제품 목록이다. 하나라도 있으면 카테고리 삭제를 막는다.
  products Product[]

  @@unique([userId, categoryName])
  @@index([userId])
}

model ProductStatus {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  statusName String
  createdAt  DateTime @default(now())

  /// 기능 : 제품 상태를 생성한 사용자다.
  user     User      @relation(fields: [userId], references: [id])
  /// 기능 : 이 상태를 사용하는 제품 목록이다. 하나라도 있으면 상태 삭제를 막는다.
  products Product[]

  @@unique([userId, statusName])
  @@index([userId])
}

model ProductMemoLog {
  id              String    @id @default(uuid()) @db.Uuid
  productId       String    @db.Uuid
  userId          String    @db.Uuid
  memoType        String
  memo            String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime? @db.Timestamptz(3)
  deletedByUserId String?   @db.Uuid
  trashExpiresAt  DateTime? @db.Timestamptz(3)

  /// 기능 : 메모가 속한 제품이다.
  product Product @relation(fields: [productId], references: [id])
  /// 기능 : 메모를 작성한 사용자다.
  user    User    @relation(fields: [userId], references: [id])

  @@index([productId, createdAt])
  @@index([userId, productId])
  @@index([userId, deletedAt])
  @@index([userId, trashExpiresAt])
}

model ProductUserPrivateMemoLog {
  id              String    @id @default(uuid()) @db.Uuid
  productId       String    @db.Uuid
  userId          String    @db.Uuid
  memoCiphertext  String
  memoKeyVersion  String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime? @db.Timestamptz(3)
  deletedByUserId String?   @db.Uuid
  trashExpiresAt  DateTime? @db.Timestamptz(3)

  /// 기능 : 비밀 메모가 속한 제품이다.
  product Product @relation(fields: [productId], references: [id])
  /// 기능 : 비밀 메모를 작성한 사용자다. 이 사용자만 복호화된 memo를 볼 수 있다.
  user    User    @relation(fields: [userId], references: [id])

  @@index([productId, createdAt])
  @@index([userId, productId])
  @@index([userId, deletedAt])
  @@index([userId, trashExpiresAt])
}

model Deal {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  dealName        String
  dealCost        Int
  dealStatus      String
  expectedEndDate DateTime  @db.Date
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime? @db.Timestamptz(3)
  deletedByUserId String?   @db.Uuid
  trashExpiresAt  DateTime? @db.Timestamptz(3)

  /// 기능 : 딜을 등록한 사용자다. 모든 딜 API는 이 userId로 소유권을 검증한다.
  user                User                     @relation(fields: [userId], references: [id])
  /// 기능 : 딜에 연결된 회사 매핑 목록이다. 딜 하나는 여러 회사와 연결될 수 있다.
  dealCompanies       DealCompany[]
  /// 기능 : 딜에 연결된 담당자 매핑 목록이다. 딜 하나는 여러 담당자와 연결될 수 있다.
  dealContacts        DealContact[]
  /// 기능 : 딜에 연결된 제품 매핑 목록이다. 딜 하나는 여러 제품을 가질 수 있다.
  dealProducts        DealProduct[]
  /// 기능 : 딜 다음 행동 로그 목록이다.
  followingActionLogs DealFollowingActionLog[]
  /// 기능 : 딜 일반 메모 로그 목록이다.
  memoLogs            DealMemoLog[]
  /// 기능 : 이 딜이 연결된 일정 매핑 목록이다.
  scheduleDeals       ScheduleDeal[]
  meetingNoteDeals    MeetingNoteDeal[]

  @@index([userId, createdAt])
  @@index([userId, dealName])
  @@index([userId, dealStatus])
  @@index([userId, expectedEndDate])
  @@index([userId, dealCost])
  @@index([userId, deletedAt])
  @@index([userId, trashExpiresAt])
}

model DealCompany {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  dealId    String   @db.Uuid
  companyId String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// 기능 : 딜-회사 연결을 만든 사용자다. 모든 딜 회사 연결은 이 userId로 소유권을 검증한다.
  user    User    @relation(fields: [userId], references: [id])
  /// 기능 : 회사가 연결된 딜이다.
  deal    Deal    @relation(fields: [dealId], references: [id])
  /// 기능 : 딜에 연결된 회사다.
  company Company @relation(fields: [companyId], references: [id])

  @@unique([dealId, companyId])
  @@index([userId, dealId])
  @@index([userId, companyId])
  @@index([companyId])
}

model DealContact {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  dealId    String   @db.Uuid
  contactId String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// 기능 : 딜-담당자 연결을 만든 사용자다. 모든 딜 담당자 연결은 이 userId로 소유권을 검증한다.
  user    User    @relation(fields: [userId], references: [id])
  /// 기능 : 담당자가 연결된 딜이다.
  deal    Deal    @relation(fields: [dealId], references: [id])
  /// 기능 : 딜에 연결된 담당자다.
  contact Contact @relation(fields: [contactId], references: [id])

  @@unique([dealId, contactId])
  @@index([userId, dealId])
  @@index([userId, contactId])
  @@index([contactId])
}

model DealProduct {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  dealId    String   @db.Uuid
  productId String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// 기능 : 딜-제품 연결을 만든 사용자다. 모든 딜 제품 연결은 이 userId로 소유권을 검증한다.
  user    User    @relation(fields: [userId], references: [id])
  /// 기능 : 제품이 연결된 딜이다.
  deal    Deal    @relation(fields: [dealId], references: [id])
  /// 기능 : 딜에 연결된 제품이다.
  product Product @relation(fields: [productId], references: [id])

  @@unique([dealId, productId])
  @@index([userId, dealId])
  @@index([userId, productId])
  @@index([productId])
}

model DealFollowingActionLog {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  dealId          String    @db.Uuid
  followingAction String
  checkComplete   Boolean   @default(false)
  createdAt       DateTime  @default(now())
