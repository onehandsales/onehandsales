  user      User               @relation(fields: [userId], references: [id])
  rows      ImportUserLogRow[]
  importJob ImportJob?

  @@index([userId, createdAt])
  @@index([userId, targetType, createdAt])
}

model ImportUserLogRow {
  id                String   @id @default(uuid()) @db.Uuid
  importUserLogId   String   @db.Uuid
  rowNumber         Int
  submittedDataJson Json
  targetLabel       String
