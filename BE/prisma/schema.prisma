model MeetingNoteDeal {
  id                          String   @id @default(uuid()) @db.Uuid
  userId                      String   @db.Uuid
  meetingNoteId               String   @db.Uuid
  dealId                      String   @db.Uuid
  dealNameSnapshot            String
  dealStatusSnapshot          String
  dealCostSnapshot            Int
  dealExpectedEndDateSnapshot DateTime @db.Date
  createdAt                   DateTime @default(now()) @db.Timestamptz(3)

  user        User        @relation(fields: [userId], references: [id])
  meetingNote MeetingNote @relation(fields: [meetingNoteId], references: [id])
  deal        Deal        @relation(fields: [dealId], references: [id])

  @@unique([meetingNoteId, dealId])
  @@index([userId, meetingNoteId])
  @@index([userId, dealId])
}

/// 기능 : 사용자가 생성한 주간 AI 영업 리포트 version 정본입니다.
model AiWeeklySalesReport {
  id                String                    @id @default(uuid()) @db.Uuid
  userId            String                    @db.Uuid
  weekStart         DateTime                  @db.Date
  weekEnd           DateTime                  @db.Date
  timeZone          String
  locale            String
  version           Int
  status            AiWeeklySalesReportStatus @default(GENERATING)
  provider          String?
  model             String?
  /// 기능 : AI가 참고한 전체 input snapshot입니다. 일반 response에 원문 전체를 반환하지 않습니다.
  inputSnapshotJson Json                      @default("{}")
  /// 기능 : snapshot count, input hash, schema version 등 원문 없는 metadata입니다.
  inputMetadataJson Json                      @default("{}")
  /// 기능 : strict JSON schema를 통과한 AI 리포트 결과입니다.
  outputJson        Json?
  /// 기능 : AI가 참고한 source 수와 누락 신호 요약입니다.
  dataCoverageJson  Json                      @default("{}")
  safeErrorCode     String?
  safeErrorMessage  String?
  requestedAt       DateTime                  @default(now()) @db.Timestamptz(3)
  startedAt         DateTime?                 @db.Timestamptz(3)
  generatedAt       DateTime?                 @db.Timestamptz(3)
  failedAt          DateTime?                 @db.Timestamptz(3)
  createdAt         DateTime                  @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime                  @default(now()) @updatedAt @db.Timestamptz(3)

  /// 기능 : 리포트를 소유한 사용자입니다. 모든 조회와 변경은 userId로 제한합니다.
  user             User                            @relation(fields: [userId], references: [id])
  /// 기능 : 이 report version에서 생성된 구조화 제안 목록입니다.
  suggestions      AiWeeklySalesReportSuggestion[]
  /// 기능 : 이 report version과 연결된 provider 호출 이력입니다. prompt/raw response는 저장하지 않습니다.
  providerCallLogs AiProviderCallLog[]
  /// Feature: follow-up messages drafted or sent from this report.
  followUpMessages FollowUpMessage[]

  @@unique([userId, weekStart, timeZone, version])
  @@index([userId, weekStart, timeZone, status])
  @@index([userId, weekStart, timeZone, version(sort: Desc)])
}

/// 기능 : 주간 AI 리포트 section에 표시할 구조화 제안입니다.
model AiWeeklySalesReportSuggestion {
  id            String                            @id @default(uuid()) @db.Uuid
  reportId      String                            @db.Uuid
  userId        String                            @db.Uuid
  type          AiWeeklySalesReportSuggestionType
  suggestionKey String
  priority      AiSuggestionPriority              @default(MEDIUM)
  title         String
  body          String
  reason        String?
  targetType    String?
  targetId      String?                           @db.Uuid
  targetPath    String?
  targetLabel   String?
  /// 기능 : follow-up 초안, cleanup 세부 정보 등 section별 구조화 payload입니다. provider raw response 전체를 넣지 않습니다.
  payloadJson   Json                              @default("{}")
  createdAt     DateTime                          @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime                          @default(now()) @updatedAt @db.Timestamptz(3)

  /// 기능 : 제안을 생성한 AI 리포트 version입니다. report 삭제 시 함께 삭제됩니다.
  report AiWeeklySalesReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  /// 기능 : 제안을 소유한 사용자입니다. report와 같은 userId를 가집니다.
  user             User              @relation(fields: [userId], references: [id])
  /// Feature: follow-up messages drafted from this report suggestion.
  followUpMessages FollowUpMessage[]

  @@unique([reportId, suggestionKey])
  @@index([userId, reportId, type])
  @@index([userId, targetType, targetId])
}

/// 기능 : AI 비동기 작업 상태를 추적합니다.
model AiJob {
  id               String              @id @default(uuid()) @db.Uuid
  userId           String              @db.Uuid
  operation        AiProviderOperation
  status           AiJobStatus         @default(PENDING)
  targetType       String
  targetId         String              @db.Uuid
  idempotencyKey   String?
  attemptCount     Int                 @default(0)
  maxAttemptCount  Int                 @default(1)
  safeErrorCode    String?
  safeErrorMessage String?
  requestedAt      DateTime            @default(now()) @db.Timestamptz(3)
  startedAt        DateTime?           @db.Timestamptz(3)
  completedAt      DateTime?           @db.Timestamptz(3)
  failedAt         DateTime?           @db.Timestamptz(3)
  /// 기능 : job 처리 metadata입니다. provider raw response나 prompt는 저장하지 않습니다.
  metadataJson     Json                @default("{}")
  createdAt        DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime            @default(now()) @updatedAt @db.Timestamptz(3)

  /// 기능 : job을 소유한 사용자입니다.
  user             User                @relation(fields: [userId], references: [id])
  /// 기능 : 이 job과 연결된 provider 호출 이력입니다.
  providerCallLogs AiProviderCallLog[]

  @@index([status, operation, createdAt])
  @@index([userId, operation, status, createdAt])
  @@index([userId, targetType, targetId])
}

/// 기능 : AI provider 호출 비용, latency, 실패 상태를 기록합니다.
model AiProviderCallLog {
  id                  String               @id @default(uuid()) @db.Uuid
  userId              String               @db.Uuid
  operation           AiProviderOperation
  status              AiProviderCallStatus @default(PENDING)
  reportId            String?              @db.Uuid
  jobId               String?              @db.Uuid
  provider            String
  model               String
  requestId           String?
  latencyMs           Int?
  inputTokenCount     Int?
  outputTokenCount    Int?
  totalTokenCount     Int?
  estimatedCostAmount Decimal?             @db.Decimal(12, 6)
  costCurrency        String               @default("USD")
  safeErrorCode       String?
  safeErrorMessage    String?
  retryable           Boolean              @default(false)
  retryCount          Int                  @default(0)
  startedAt           DateTime             @default(now()) @db.Timestamptz(3)
  completedAt         DateTime?            @db.Timestamptz(3)
  failedAt            DateTime?            @db.Timestamptz(3)
  /// 기능 : redacted provider metadata입니다. prompt, raw response, API key, quota detail은 저장하지 않습니다.
  metadataJson        Json                 @default("{}")
  createdAt           DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime             @default(now()) @updatedAt @db.Timestamptz(3)

  /// 기능 : provider 호출을 발생시킨 사용자입니다.
  user   User                 @relation(fields: [userId], references: [id])
  /// 기능 : 관련 AI 주간 리포트입니다. report 삭제 시 이력은 남기고 연결만 해제합니다.
  report AiWeeklySalesReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  /// 기능 : 관련 AI job입니다. job 삭제 시 이력은 남기고 연결만 해제합니다.
  job    AiJob?               @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([userId, operation, createdAt])
  @@index([reportId, createdAt])
  @@index([jobId, createdAt])
  @@index([status, createdAt])
}

/// Feature: external email account connection for user-confirmed follow-up email delivery.
model ExternalEmailConnection {
  id                    String                        @id @default(uuid()) @db.Uuid
  userId                String                        @db.Uuid
  provider              ExternalEmailProvider
  providerAccountId     String?
  providerAccountEmail  String
  status                ExternalEmailConnectionStatus @default(CONNECTED)
  encryptedAccessToken  String
  encryptedRefreshToken String?
  tokenExpiresAt        DateTime?                     @db.Timestamptz(3)
  grantedScopes         String[]                      @default([])
  connectedAt           DateTime                      @default(now()) @db.Timestamptz(3)
  disconnectedAt        DateTime?                     @db.Timestamptz(3)
  reconnectRequiredAt   DateTime?                     @db.Timestamptz(3)
  lastSentAt            DateTime?                     @db.Timestamptz(3)
  lastSendSafeErrorCode String?
  createdAt             DateTime                      @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime                      @default(now()) @updatedAt @db.Timestamptz(3)

  /// Feature: connection owner. All reads and writes must be scoped by userId.
  user             User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  /// Feature: follow-up email messages that used this connection.
  followUpMessages FollowUpMessage[]

  @@unique([userId, provider])
  @@index([userId, status])
}

/// Feature: short-lived OAuth state used to bind external email callback to the authenticated user.
model ExternalEmailOAuthState {
  id          String                @id @default(uuid()) @db.Uuid
  userId      String                @db.Uuid
  provider    ExternalEmailProvider
  stateHash   String
  redirectUri String
  expiresAt   DateTime              @db.Timestamptz(3)
  consumedAt  DateTime?             @db.Timestamptz(3)
  createdAt   DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime              @default(now()) @updatedAt @db.Timestamptz(3)

  /// Feature: OAuth state owner. Raw state is never persisted.
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([stateHash])
  @@index([userId, provider, expiresAt])
}

/// Feature: verified SMS sender number. Raw E.164 number is stored only as encrypted ciphertext.
model SmsSenderNumber {
  id                    String                @id @default(uuid()) @db.Uuid
  userId                String                @db.Uuid
  phoneE164Hash         String
  phoneE164Ciphertext   String
  phoneE164Masked       String
  status                SmsSenderNumberStatus @default(PENDING_VERIFICATION)
  provider              String?
  providerSenderId      String?
  verificationCodeHash  String?
  verificationExpiresAt DateTime?             @db.Timestamptz(3)
  verifiedAt            DateTime?             @db.Timestamptz(3)
  revokedAt             DateTime?             @db.Timestamptz(3)
  lastSentAt            DateTime?             @db.Timestamptz(3)
  lastSendSafeErrorCode String?
  createdAt             DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime              @default(now()) @updatedAt @db.Timestamptz(3)

  /// Feature: sender owner. Phone uniqueness is checked by HMAC hash per user.
  user             User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  /// Feature: follow-up SMS messages that used this sender number.
  followUpMessages FollowUpMessage[]

  @@unique([userId, phoneE164Hash])
  @@index([userId, status, createdAt])
}

/// Feature: records that a user acknowledged the legal/consent notice for a channel.
model FollowUpConsentNotice {
  id             String                  @id @default(uuid()) @db.Uuid
  userId         String                  @db.Uuid
  channel        FollowUpDeliveryChannel
  acknowledgedAt DateTime                @default(now()) @db.Timestamptz(3)
  createdAt      DateTime                @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime                @default(now()) @updatedAt @db.Timestamptz(3)

  /// Feature: consent owner. One latest acknowledgement row is kept per channel.
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([userId, channel])
}

/// Feature: follow-up draft and delivery history generated from AI report suggestions or user edits.
model FollowUpMessage {
  id                       String                  @id @default(uuid()) @db.Uuid
  userId                   String                  @db.Uuid
  sourceReportId           String?                 @db.Uuid
  sourceSuggestionId       String?                 @db.Uuid
  channel                  FollowUpDeliveryChannel
  status                   FollowUpMessageStatus   @default(DRAFT)
  languageTag              String
  emailConnectionId        String?                 @db.Uuid
  smsSenderNumberId        String?                 @db.Uuid
  senderDisplayName        String?
  senderEmail              String?
  senderPhoneE164Masked    String?
  recipientContactId       String?                 @db.Uuid
  recipientName            String
  recipientEmail           String?
  recipientPhoneE164Masked String?
  subject                  String?
  body                     String                  @db.Text
  bodyPreview              String
  provider                 String?
  providerMessageId        String?
  safeErrorCode            String?
  safeErrorMessage         String?
  retryable                Boolean                 @default(false)
  retryCount               Int                     @default(0)
  sentAt                   DateTime?               @db.Timestamptz(3)
  failedAt                 DateTime?               @db.Timestamptz(3)
  createdAt                DateTime                @default(now()) @db.Timestamptz(3)
  updatedAt                DateTime                @default(now()) @updatedAt @db.Timestamptz(3)

  /// Feature: message owner. All history queries must include userId.
  user             User                           @relation(fields: [userId], references: [id], onDelete: Restrict)
  /// Feature: source AI report. History remains if a report version is removed.
  sourceReport     AiWeeklySalesReport?          @relation(fields: [sourceReportId], references: [id], onDelete: SetNull)
  /// Feature: source AI follow-up suggestion. History remains if a suggestion is removed.
  sourceSuggestion AiWeeklySalesReportSuggestion? @relation(fields: [sourceSuggestionId], references: [id], onDelete: SetNull)
  /// Feature: email account used by an email follow-up.
  emailConnection  ExternalEmailConnection?       @relation(fields: [emailConnectionId], references: [id], onDelete: SetNull)
  /// Feature: sender number used by an SMS follow-up.
  smsSenderNumber  SmsSenderNumber?               @relation(fields: [smsSenderNumberId], references: [id], onDelete: SetNull)
  /// Feature: CRM contact recipient. History remains if contact is removed.
  recipientContact Contact?                       @relation(fields: [recipientContactId], references: [id], onDelete: SetNull)
  /// Feature: timeline target links related to this follow-up.
  targets          FollowUpMessageTarget[]
  /// Feature: provider delivery attempts for this follow-up.
  deliveryAttempts FollowUpDeliveryAttempt[]

  @@index([userId, channel, status, createdAt])
  @@index([userId, sourceReportId, createdAt])
  @@index([recipientContactId, createdAt])
}

/// Feature: stable target references used to show follow-up history on report/deal/contact timelines.
model FollowUpMessageTarget {
  id          String             @id @default(uuid()) @db.Uuid
  userId      String             @db.Uuid
  messageId   String             @db.Uuid
  targetType  FollowUpTargetType
  targetId    String             @db.Uuid
  targetPath  String
  targetLabel String?
  createdAt   DateTime           @default(now()) @db.Timestamptz(3)

  /// Feature: target owner. Duplicates are scoped by message and concrete target.
  user    User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  /// Feature: parent follow-up message. Message deletion removes only child target rows.
  message FollowUpMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, targetType, targetId])
  @@index([userId, targetType, targetId, createdAt])
}

/// Feature: provider attempt log for follow-up email/SMS delivery with safe, redacted metadata only.
model FollowUpDeliveryAttempt {
  id                  String                        @id @default(uuid()) @db.Uuid
  userId              String                        @db.Uuid
  messageId           String                        @db.Uuid
  channel             FollowUpDeliveryChannel
  status              FollowUpDeliveryAttemptStatus @default(PENDING)
  attemptNumber       Int                           @default(1)
  provider            String?
  providerMessageId   String?
  providerStatusCode  String?
  safeErrorCode       String?
  safeErrorMessage    String?
  retryable           Boolean                       @default(false)
  nextRetryAt         DateTime?                     @db.Timestamptz(3)
  latencyMs           Int?
  estimatedCostAmount Decimal?                      @db.Decimal(12, 6)
  costCurrency        String                        @default("USD")
  sentAt              DateTime?                     @db.Timestamptz(3)
  failedAt            DateTime?                     @db.Timestamptz(3)
  detailJson          Json                          @default("{}")
  createdAt           DateTime                      @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime                      @default(now()) @updatedAt @db.Timestamptz(3)

  /// Feature: attempt owner. Operational/admin queries must include userId.
  user    User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  /// Feature: parent follow-up message. Message deletion removes only child attempt rows.
  message FollowUpMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
  @@index([userId, channel, status, createdAt])
  @@index([status, nextRetryAt])
}

