@baseUrl = http://localhost:3000
@accessToken = replace-with-backend-app-access-token
@contactId = replace-with-contact-id
@companyId = replace-with-company-id
@contactDepartmentId = replace-with-contact-department-id
@contactJobGradeId = replace-with-contact-job-grade-id
@memoLogId = replace-with-memo-log-id
@privateMemoLogId = replace-with-private-memo-log-id
@cursor = replace-with-next-cursor

### Health
GET {{baseUrl}}/api/health

### List contacts
GET {{baseUrl}}/api/contacts?page=1&username=&companyId=&contactDepartmentId=&contactJobGradeId=
Authorization: Bearer {{accessToken}}

### List contact company options
GET {{baseUrl}}/api/contacts/company-options
Authorization: Bearer {{accessToken}}

### List contact job grades
GET {{baseUrl}}/api/contact-job-grades
Authorization: Bearer {{accessToken}}

### Create contact job grade
POST {{baseUrl}}/api/contact-job-grades
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "jobGradeName": "팀장"
}

### Delete contact job grade
DELETE {{baseUrl}}/api/contact-job-grades/{{contactJobGradeId}}
Authorization: Bearer {{accessToken}}

### List contact departments
GET {{baseUrl}}/api/contact-departments
Authorization: Bearer {{accessToken}}

### Create contact department
POST {{baseUrl}}/api/contact-departments
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "departmentName": "영업팀"
}

### Delete contact department
DELETE {{baseUrl}}/api/contact-departments/{{contactDepartmentId}}
Authorization: Bearer {{accessToken}}

### Create contact
POST {{baseUrl}}/api/contacts
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "username": "홍길동",
  "mobile": "010-1111-2222",
  "email": "contact@example.com",
  "companyId": "{{companyId}}",
  "contactDepartmentId": "{{contactDepartmentId}}",
  "contactJobGradeId": "{{contactJobGradeId}}",
  "contactMemo": "첫 미팅에서 주요 요구사항을 확인했다."
}

### Get contact
GET {{baseUrl}}/api/contacts/{{contactId}}
Authorization: Bearer {{accessToken}}

### Update contact
PATCH {{baseUrl}}/api/contacts/{{contactId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "username": "홍길동",
  "mobile": "010-3333-4444",
  "email": "contact.updated@example.com",
  "companyId": "{{companyId}}",
  "contactDepartmentId": "{{contactDepartmentId}}",
  "contactJobGradeId": "{{contactJobGradeId}}"
}

### Create contact memo log
POST {{baseUrl}}/api/contacts/{{contactId}}/memo-logs
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "memoType": "전화 통화",
  "memo": "담당자와 다음 미팅 일정을 조율했다."
}

### List contact memo logs
GET {{baseUrl}}/api/contacts/{{contactId}}/memo-logs
Authorization: Bearer {{accessToken}}

### List contact memo logs with cursor
GET {{baseUrl}}/api/contacts/{{contactId}}/memo-logs?cursor={{cursor}}
Authorization: Bearer {{accessToken}}

### Update contact memo log
PATCH {{baseUrl}}/api/contacts/{{contactId}}/memo-logs/{{memoLogId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "memoType": "후속 통화",
  "memo": "수정된 일반 메모"
}

### Create contact private memo log
POST {{baseUrl}}/api/contacts/{{contactId}}/private-memo-logs
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "memo": "본인만 볼 수 있는 담당자 비밀 메모"
}

### List contact private memo logs
GET {{baseUrl}}/api/contacts/{{contactId}}/private-memo-logs
Authorization: Bearer {{accessToken}}

### List contact private memo logs with cursor
GET {{baseUrl}}/api/contacts/{{contactId}}/private-memo-logs?cursor={{cursor}}
Authorization: Bearer {{accessToken}}

### Update contact private memo log
PATCH {{baseUrl}}/api/contacts/{{contactId}}/private-memo-logs/{{privateMemoLogId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "memo": "수정된 개인 비밀 메모"
}
